# ── Frontend environment variables ───────────────────────────────────────────
# Copy to .env.local for local overrides (never commit .env.local)

VITE_API_URL=https://clixworks.co.tz

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Measurement ID from your GA4 property. GA is disabled in dev mode automatically.
VITE_GA_MEASUREMENT_ID=G-QWS1WMX4ZS

# ── Google Search Console Verification ───────────────────────────────────────
# Paste the content value from the HTML verification meta tag provided by GSC.
# Example: VITE_GSC_VERIFICATION=abc123xyz
# Leave blank if not yet verified.
VITE_GSC_VERIFICATION=

# ── Bing Webmaster Tools Verification ────────────────────────────────────────
# Paste the content value from the msvalidate.01 meta tag provided by Bing.
# Example: VITE_BING_VERIFICATION=abc123xyz
# Leave blank if not yet verified.
VITE_BING_VERIFICATION=
